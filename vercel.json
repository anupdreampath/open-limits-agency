{
  "version": 2,
  "buildCommand": "next build",
  "devCommand": "next dev -p 3000",
  "installCommand": "npm install",
  "framework": "nextjs",
  "rewrites": [
    { "source": "/aboutus", "destination": "/aboutus/" },
    { "source": "/portfolio", "destination": "/portfolio/" },
    { "source": "/home", "destination": "/" }
  ],
  "redirects": [
    { "source": "/about", "destination": "/aboutus/", "permanent": true },
    { "source": "/work", "destination": "/portfolio/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/((?!api).*)\\.(js|css|svg|png|jpg|jpeg|gif|webp|ico|woff|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
